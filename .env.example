# Trading mode: dry_run (default), paper, live
TRADING_MODE=dry_run

# Alpaca (paper: https://paper-api.alpaca.markets)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# Optional: LLM signal enrichment (falls back to keyword rules if unset)
ANTHROPIC_API_KEY=

# Poll interval in seconds (Truth Social CDN caches ~2-3s; use >=3)
POLL_INTERVAL=5
